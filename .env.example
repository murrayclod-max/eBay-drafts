# App password - what you type to log into DraftIt
APP_PASSWORD=choose-a-strong-password-here

# Random secret for sessions (generate one at: https://randomkeygen.com)
SESSION_SECRET=some-long-random-string-here

# Claude API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# eBay Developer credentials (from developer.ebay.com after approval)
EBAY_CLIENT_ID=YourAppID-here
EBAY_CLIENT_SECRET=YourCertID-here

# The full URL where your app lives (no trailing slash)
APP_URL=https://drafts.dbmjr.com
EBAY_REDIRECT_URI=https://drafts.dbmjr.com/ebay/callback

# PORT is set automatically by Railway — don't change this
# PORT=3000
